{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "prod": "NODE_ENV=production node dist/index.js",
    "dev": "cross-env NODE_ENV=local nodemon --watch . --ext ts,js,json --ignore dist --ignore coverage --exec \"ts-node --transpile-only index.ts\"",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles --verbose --coverage --logHeapUsage --watchAll --no-cache --clearMocks --no-compilation-cache --bail",
    "test:ci": "cross-env NODE_ENV=test jest --ci --verbose --watchAll=false --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json --noCheck",
    "format": "prettier --write --cache . --ignore-path .prettierignore",
    "format:check": "prettier --check --cache . --ignore-path .prettierignore",
    "pre-commit": "lint-staged",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,cjs,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
