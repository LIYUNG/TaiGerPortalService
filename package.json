    "@aws-sdk/client-sts": "^3.665.0",
    "@aws-sdk/signature-v4": "^3.374.0",
    "@aws-sdk/util-stream-node": "^3.374.0",
    "@faker-js/faker": "^8.4.1",
    "@taiger-common/core": "^1.1.2",
    "@taiger-common/model": "^1.0.59",
    "async": "^3.2.4",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.0",
    "bottleneck": "^2.19.5",
    "child_process": "^1.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "debug": "~2.6.9",
    "dotenv": "^10.0.0",
    "drizzle-orm": "^0.44.2",
    "ejson": "^2.2.3",
    "errorhandler": "^1.5.1",
    "express": "^4.18.1",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.12.0",
    "generate-password": "^1.7.0",
    "google-auth-library": "^10.2.0",
    "googleapis": "^118.0.0",
    "helmet": "^6.0.0",
    "http-errors": "~1.6.3",
    "https": "^1.0.0",
    "ical-generator": "^3.6.1",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^2.5.1",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.21",
    "mammoth": "^1.8.0",
