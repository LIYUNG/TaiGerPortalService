    "@taiger-common/model": "^1.0.61",
    "async": "^3.2.4",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.0",
    "bottleneck": "^2.19.5",
    "child_process": "^1.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "debug": "~2.6.9",
    "dotenv": "^10.0.0",
